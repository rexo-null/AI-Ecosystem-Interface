{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ISKIN",
  "version": "0.1.0-alpha",
  "identifier": "com.iskin.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ISKIN - AI IDE",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  },
  "plugins": {
    "shell": {
      "open": true,
      "execute": true,
      "sidecar": false
    },
    "fs": {
      "scope": ["**"]
    }
  }
}
